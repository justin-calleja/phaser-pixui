{
  "name": "phaser-pixui",
  "version": "0.1.6",
  "description": "A UI library for Phaser game engine that provides responsive and customizable UI components, tailored specifically for pixel art games",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "test": "playwright test",
    "test:update": "playwright test --update-snapshots",
    "test:install": "playwright install chromium && npm run example:install",
    "example": "cd example && npm run dev",
    "example:install": "cd example && npm install"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skhoroshavin/phaser-pixui.git"
  },
  "homepage": "https://skhoroshavin.itch.io/phaser-pixui",
  "bugs": {
    "url": "https://github.com/skhoroshavin/phaser-pixui/issues"
  },
  "keywords": [
    "phaser",
    "phaser4",
    "ui",
    "pixui",
    "pixel-art",
    "game-ui",
    "webgl",
    "canvas",
    "typescript",
    "responsive",
    "pixel-perfect"
  ],
  "author": "Sergei Khoroshavin",
  "license": "MIT",
  "type": "commonjs",
  "peerDependencies": {
    "phaser": "^4.0.0-rc.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.2",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
